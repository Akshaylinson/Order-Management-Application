<?xml version="1.0" encoding="utf-8"?>
<!-- White-filled drawable used as windowSplashScreenAnimatedIcon on Android 12+
     so the icon is invisible against the white splash background.
     An empty/transparent vector causes Android to fall back to the launcher icon. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M0,0 H108 V108 H0 Z"/>
</vector>
